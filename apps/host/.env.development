NODE_ENV=development
PORT=3000

# Allows to fallback to deployed remotes in development
ENABLE_REMOTE_FALLBACK=true

PRODUCT_LISTING_REMOTE_URL_LOCAL=http://localhost:3001/remoteEntry.js
PRODUCT_DETAILS_REMOTE_URL_LOCAL=http://localhost:3002/remoteEntry.js
CART_REMOTE_URL_LOCAL=http://localhost:3003/remoteEntry.js
CHECKOUT_REMOTE_URL_LOCAL=http://localhost:3004/remoteEntry.js
USER_PROFILE_REMOTE_URL_LOCAL=http://localhost:3005/remoteEntry.js

PRODUCT_LISTING_REMOTE_URL=https://ecom-mfe-product-listing.vercel.app/remoteEntry.js
PRODUCT_DETAILS_REMOTE_URL=https://ecom-mfe-product-details.vercel.app/remoteEntry.js
CART_REMOTE_URL=https://ecom-mfe-cart.vercel.app/remoteEntry.js
CHECKOUT_REMOTE_URL=https://ecom-mfe-checkout.vercel.app/remoteEntry.js
USER_PROFILE_REMOTE_URL=https://ecom-mfe-user-profile.vercel.app/remoteEntry.js

# Allowed origins are the origins that are allowed to access the "host" app (comma separated list of origins)
ALLOWED_ORIGINS=